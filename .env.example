# ==========================================
# AI for Enterprise Cost Intelligence
# Environment Variables Template
# Copy this file to `.env` and replace the
# placeholder values with your actual values.
# ==========================================

# ------------------------------------------
# Application Settings
# ------------------------------------------
APP_NAME=AI for Enterprise Cost Intelligence API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ------------------------------------------
# API Configuration
# ------------------------------------------
API_V1_PREFIX=/api/v1

# ------------------------------------------
# OpenAI Configuration
# ------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# ------------------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------------------
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/cost_intelligence

# ------------------------------------------
# AWS Configuration
# ------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1

# ------------------------------------------
# Amazon S3 Configuration
# ------------------------------------------
S3_BUCKET_NAME=your_s3_bucket_name

# ------------------------------------------
# Security
# ------------------------------------------
SECRET_KEY=your_super_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------
# File Upload Settings
# ------------------------------------------
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=csv,xlsx,json

# ------------------------------------------
# Logging
# ------------------------------------------
LOG_LEVEL=INFO